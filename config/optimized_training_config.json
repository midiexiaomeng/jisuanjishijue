{
  "data_path": "data/YOLO",
  "epochs": 200,
  "batch_size": 2,
  "learning_rate": 0.001,
  "img_size": 416,
  "device": "cuda",
  "save_dir": "checkpoints/faster_rcnn_optimized/",
  "use_real_training": true,
  "conf_threshold": 0.25,
  "iou_threshold": 0.45,
  "max_det": 300,
  "project": "runs/detect",
  "name": "train_optimized",
  "optimizer": "AdamW",
  "momentum": 0.937,
  "weight_decay": 0.0005,
  "warmup_epochs": 3,
  "warmup_momentum": 0.8,
  "box": 7.5,
  "cls": 0.5,
  "dfl": 1.5,
  "label_smoothing": 0.0,
  "use_amp": true,
  "gradient_accumulation_steps": 4,
  "num_workers": 0,
  "pin_memory": true,
  "augmentation": {
    "hsv_h": 0.015,
    "hsv_s": 0.7,
    "hsv_v": 0.4,
    "degrees": 0.0,
    "translate": 0.1,
    "scale": 0.5,
    "shear": 0.0,
    "perspective": 0.0,
    "flipud": 0.0,
    "fliplr": 0.5,
    "mosaic": 1.0,
    "mixup": 0.0,
    "copy_paste": 0.0
  },
  "optimization": {
    "mixed_precision": true,
    "gradient_checkpointing": false,
    "cudnn_benchmark": true,
    "cudnn_deterministic": false,
    "empty_cache_frequency": 10
  }
}
